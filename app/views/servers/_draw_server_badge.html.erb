<!-- Display badge on server how have current cluster or owner -->
<% if @cluster && server.cluster == @cluster
     current_filter_object = @cluster
     parent_type = current_filter_object.class.name
   elsif @manager && server.manager == @manager
     current_filter_object = @manager
     parent_type = "Managernaire"
   end
  if current_filter_object %>
<span class="server_badge" title="<%= @current_filter_object %>"
      style="background-color:<%= Color.find_by(parent_type: parent_type, parent_id: current_filter_object.to_s).try(:code) %> !important;" >
</span>
<% end %>
