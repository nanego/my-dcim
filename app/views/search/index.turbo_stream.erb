<%= turbo_stream.replace "search-index" do %>
  <turbo-frame id="search-index" data-controller="search-results">
    <% if @results.any? %>
      <div class="list-group">
        <%= render partial: "result", collection: @results %>
      </div>
    <% else %>
      <%= render CardEmptyDataComponent.new(text: t(".no_results_found")) %>
    <% end %>
  </turbo-frame>
<% end %>
