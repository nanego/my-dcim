<% breadcrumb.add_step(title = t(".results")) %>

<%= render Page::HeadingComponent.new(title:, breadcrumb:) %>

<div class="p-4 border-top d-flex flex-column row-gap-4">
  <div class="d-lg-none">
    <%= render partial: "search_field", locals: { quick_search: false } %>
  </div>
  <turbo-frame
    id="search-index"
    data-controller="search-results"
    data-turbo-action="advance">
    <% if @results.any? %>
      <div class="list-group">
        <%= render partial: "result", collection: @results %>
        <% if @more_results %>
          <%= link_to search_path(search_query: params[:search_query]), class: "list-group-item list-group-item-action d-inline-flex align-items-center", data: { turbo_frame: "_top" } do %>
            <span class="bi bi-search fs-5 p-2 me-3 text-primary"></span>
            <h5 class="me-2 mb-0"><%= t(".see_more", query: params[:search_query]) %></h5>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render CardEmptyDataComponent.new(text: t(".no_results_found")) %>
    <% end %>
  </turbo-frame>
</div>
