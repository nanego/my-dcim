<div class="my-4 my-lg-0 mx-lg-auto order-0 order-lg-1 position-relative">
  <%= form_with url: search_path,
                id: "search-form",
                method: :get,
                data: {
                  turbo: true,
                  turbo_frame: "search-index",
                  controller: "global-search",
                },
                class: "d-flex" do |f| %>

    <div class="input-group">
      <%= f.search_field :search_query,
                         value: params[:search_query],
                         autocomplete: "off",
                         data: {
                           global_search_target: "searchInput",
                           action: "input->global-search#submit",
                         },
                         class: "form-control border-primary",
                         placeholder: t("filters.placeholder.quicksearch") %>

      <%= f.button class: "btn btn-primary", type: "submit" do %>
        <span class="bi bi-search"></span>
        <span class="loading spinner-border spinner-border-sm"></span>
      <% end %>
    </div>
  <% end %>

  <% if request.path != search_path %>
    <turbo-frame
      id="search-index"
      class="search-dropdown position-absolute top-100 start-50 translate-middle-x overflow-auto z-3 mt-3 border-bottom rounded-bottom"
      data-controller="search-results"
      data-search-results-target="popup"
      data-action="click@document->search-results#closeForOusideClick"
      data-action="keydown@document->search-results#closeForEscape"
    />
  <% end %>
</div>
