<% breadcrumb.add_step(title = Manager.model_name.human.pluralize) %>

<%= render Page::HeadingComponent.new(title:, breadcrumb:) do |heading| %>
  <% heading.with_right_content do %>
    <% render ButtonComponent.new(
      t(".new_manager"),
      url: new_manager_path,
      variant: :success,
      icon: "plus-lg",
      is_responsive: true
    ) if allowed_to?(:create?) %>
  <% end %>
<% end %>

<div class="p-4 border-top d-flex flex-column row-gap-4">
  <%= render List::DataTableComponent.new(@managers) do |table| %>
    <% if allowed_to?(:destroy?) %>
      <% table.with_bulk_action(
        url: bulk_managers_path,
        method: :delete,
        class: "btn btn-danger btn-sm",
        data: { confirm: t("action.confirm") }
      ) do %>
        <span class="bi bi-trash pe-none" title="<%= t("action.delete") %>"></span>
      <% end %>
    <% end %>

    <% table.with_column(Manager.human_attribute_name(:name), sort_by: :name) do |manager| %>
      <%= link_to manager, manager_path(manager), class: "fw-bold" %>
    <% end %>

    <% table.with_column(Manager.human_attribute_name(:usage), sort_by: :servers_count) do |manager| %>
      <%= link_to Manager.human_attribute_name(:servers_count, count: manager.servers_count),
                  servers_path(manager_ids: manager.id) %>
    <% end %>

    <% table.with_column(style: "min-width: 70px; width: 70px") do |manager| %>
      <div class="btn-group btn-group-sm" role="group" aria-label="...">
        <% if allowed_to?(:update?, manager) %>
          <%= link_to edit_manager_path(manager), class: "btn btn-info" do %>
            <span class="bi bi-pencil" title="<%= t("action.edit") %>" aria-hidden="true"
                                                                      data-controller="tooltip"
                                                                      data-bs-placement="left"></span>
            <span class="visually-hidden"><%= t("action.edit") %></span>
          <% end %>
        <% end %>

        <% if allowed_to?(:destroy?, manager) %>
          <%= link_to manager, method: :delete, class: "btn btn-danger" do %>
            <span class="bi bi-trash" title="<%= t("action.delete") %>" aria-hidden="true"
                                                                        data-controller="tooltip"
                                                                        data-bs-placement="left"></span>
            <span class="visually-hidden"><%= t("action.delete") %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
