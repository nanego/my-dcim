<%
  breadcrumb.add_step(title = PowerDistributionUnit.model_name.human.pluralize)
%>

<%= render Page::HeadingComponent.new(title:, breadcrumb:) do |heading| %>
  <% heading.with_right_content do %>
    <% render ButtonComponent.new(t(".new_power_distribution_unit"),
                                  url: new_power_distribution_unit_path,
                                  variant: :success,
                                  icon: "plus-lg",
                                  is_responsive: true) %>
  <% end %>
<% end %>

<div class="p-4 border-top d-flex flex-column row-gap-4">
  <%= render List::DataTableComponent.new(@power_distribution_units) do |table| %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:type_id)) do |power_distribution_unit| %>
      <%= power_distribution_unit.type_id %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:bay_id)) do |power_distribution_unit| %>
      <%= power_distribution_unit.bay_id %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:side)) do |power_distribution_unit| %>
      <%= power_distribution_unit.side %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:orientation)) do |power_distribution_unit| %>
      <%= power_distribution_unit.orientation %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:name)) do |power_distribution_unit| %>
      <%= power_distribution_unit.name %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:slug)) do |power_distribution_unit| %>
      <%= power_distribution_unit.slug %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:ipmi_url)) do |power_distribution_unit| %>
      <%= power_distribution_unit.ipmi_url %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:serial_number)) do |power_distribution_unit| %>
      <%= power_distribution_unit.serial_number %>
    <% end %>
    <% table.with_column(PowerDistributionUnit.human_attribute_name(:comment)) do |power_distribution_unit| %>
      <%= power_distribution_unit.comment %>
    <% end %>

    <% table.with_column(style: "min-width: 70px; width: 70px") do |power_distribution_unit| %>
      <div class="btn-group btn-group-sm" role="group" aria-label="...">
        <%= link_to edit_power_distribution_unit_path(power_distribution_unit), class: "btn btn-info" do %>
          <span class="bi bi-pencil"
                title="<%= t("action.edit") %>"
                data-controller="tooltip"
                data-bs-placement="left"
                aria-hidden="true"></span>
          <span class="visually-hidden"><%= t("action.edit") %></span>
        <% end %>
        <%= link_to power_distribution_unit_path(power_distribution_unit),
                    method: :delete,
                    data: { confirm: t("action.confirm") },
                    class: "btn btn-danger" do %>
          <span class="bi bi-trash"
                title="<%= t("action.delete") %>"
                data-controller="tooltip"
                data-bs-placement="left"
                aria-hidden="true"></span>
          <span class="visually-hidden"><%= t("action.delete") %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
