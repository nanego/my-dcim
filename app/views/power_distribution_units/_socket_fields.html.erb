<li class="nested-form-wrapper list-group-item bg-transparent"
    data-new-record="<%= f.object.new_record? %>">

  <div class="d-flex flex-column">
    <fieldset class="d-flex">
      <%= f.select :port_type_id,
                   PowerDistributionUnitSocketDecorator.port_type_options_for_select,
                   { prompt: true },
                   {
                     class: "form-select form-select-sm",
                     data: {
                       controller: :select,
                       select_clear_button_title_value: t("action.clear_all"),
                     },
                     placeholder: PowerDistributionUnit::Socket.human_attribute_name(:port_type_id),
                   } %>
    </fieldset>

    <span class="d-inline-flex align-items-center justify-content-between mt-2">
      <fieldset>
        <%= f.number_field :number, { class: "form-control form-control-sm", placeholder: true } %>
      </fieldset>

      <fieldset class="text-end">
        <%= f.hidden_field :_destroy %>
        <button type="button" data-action="nested-form#remove" class="btn text-danger btn-sm" id="input-group-delete-btn">
          <span class="bi bi-trash" title="<%= t("action.delete") %>"></span>
        </button>
      </fieldset>
    </span>
  </div>
</li>
