<%# locals: (air_conditioner_model:) -%>

<%= form_with(model: air_conditioner_model, html: { role: "form" }) do |f| %>
  <%= render FormErrorsComponent.new(air_conditioner_model) %>

  <div class="row row-cols-1 row-cols-lg-2 row-gap-4">
    <div class="col">
      <%= render CardComponent.new(extra_classes: "bg-body-tertiary") do |card| %>
        <fieldset class="col-12 ">
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, class: "form-control" %>
        </fieldset>
        <fieldset class="col-12 mt-4">
          <%= f.label :manufacturer_id, class: "form-label" %>
          <%= f.select :manufacturer_id,
                       AirConditionerModelDecorator.manufacturers_options_for_select,
                       { prompt: true },
                       {
                         class: "form-select",
                         data: { controller: "select" },
                         placeholder: t("select.placeholder"),
                       } %>
        </fieldset>
      <% end %>
    </div>
  </div>

  <%= render Form::ActionsComponent.new(f) %>
<% end %>
